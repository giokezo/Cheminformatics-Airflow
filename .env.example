# Copy to .env and fill in. Docker Compose injects these as Airflow Connections
# (AIRFLOW_CONN_*), so secrets live only in the environment and are masked in task logs.

# MS Teams incoming webhook (Step 3 notifications). Ask your team for the real URL.
AIRFLOW_CONN_MSTEAMS_WEBHOOK=https://ask-your-team-to-provide-you-with-this-url

# S3-compatible object storage (MinIO in local dev).
AIRFLOW_CONN_AWS_S3=aws://minio_access_key:minio_secret_key@/?endpoint_url=http%3A%2F%2Fstorage%3A9000&region_name=us-east-1

# Postgres data warehouse (silver/gold layers + Soda data source).
AIRFLOW_CONN_DWH_CONNECTION=postgres://postgres:123456@local-db:5432/postgres

# Optional: extra pip requirements installed at container start (e.g. faerun/tmap-viz).
# _PIP_ADDITIONAL_REQUIREMENTS=faerun tmap-viz
